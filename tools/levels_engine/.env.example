# ── LIVE keys (required for options chain / OPRA data) ──
ALPACA_API_KEY_LIVE=PASTE_LIVE_KEY_ID_HERE
ALPACA_API_SECRET_LIVE=PASTE_LIVE_SECRET_HERE

# ── PAPER keys (for paper trading; fill in if needed) ──
ALPACA_API_KEY_PAPER=PASTE_PAPER_KEY_ID_HERE
ALPACA_API_SECRET_PAPER=PASTE_PAPER_SECRET_HERE

# ── Auth mode selectors ──
#   live  = use *_LIVE keys   (required for options chain / OPRA)
#   paper = use *_PAPER keys  (paper trading, free stock data)
ALPACA_OPTIONS_AUTH=live
ALPACA_TRADING_AUTH=paper
ALPACA_DATA_FEED=indicative

# ── SEC EDGAR ──
SEC_USER_AGENT=QuantLabLevelsEngine your-email@example.com
SEC_LOOKBACK_DAYS=45
SEC_MAX_FILINGS=20
